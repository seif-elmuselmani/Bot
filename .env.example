# Telegram Bot Configuration
# Retrieve your BOT_TOKEN from BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Telegram group ID where admin approvals and orders will be forwarded
# Note: Usually starts with a minus sign (e.g. -100123456789)
ADMIN_GROUP_ID=-1000000000000

# MongoDB Connection String
# Replace with your local or MongoDB Atlas connection URI
MONGODB_URI=mongodb://localhost:27017/savetimepro_db

# Application environment configuration
NODE_ENV=development
PORT=3000
